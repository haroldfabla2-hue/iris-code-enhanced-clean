# Configuración del Sistema Multi-Agente Superior
# =================================================

# API Keys para LLM Router
# ------------------------
# MiniMax M2: Gratis hasta 7 Nov 2025
# Obtener en: https://api.minimax.chat/
MINIMAX_API_KEY=tu_minimax_api_key_aqui

# OpenRouter: Múltiples modelos (Llama, GPT-4, Claude, etc.)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu_clave_openrouter_aqui

# Base de Datos PostgreSQL (Docker)
# ---------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agente_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password

# Redis Cache (Docker)
# -------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Configuración de Aplicación
# -------------------------
APP_NAME="Sistema Multi-Agente Superior"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Límites del Sistema
# ------------------
MAX_CONCURRENT_AGENTS=5
MAX_TOOLS_PER_AGENT=3
AGENT_TIMEOUT_SECONDS=120
LLM_TIMEOUT_SECONDS=30

# Observabilidad y Monitoreo
# -------------------------
ENABLE_TRACING=true
METRICS_PORT=9090

# Modelos Disponibles en OpenRouter
# --------------------------------
# - llama70b: meta-llama/llama-3.3-70b-instruct
# - llama31_70b: meta-llama/llama-3.1-70b-instruct  
# - gpt4: openai/gpt-4
# - gpt4_turbo: openai/gpt-4-turbo
# - claude3: anthropic/claude-3-sonnet
# - claude3_5: anthropic/claude-3-5-sonnet
# - gemini: google/gemini-pro

# Rate Limits por Proveedor
# -------------------------
# MiniMax M2: 60/minuto
# OpenRouter Llama: 40/minuto
# OpenRouter GPT-4: 20/minuto
# OpenRouter Claude: 35/minuto
# OpenRouter Gemini: 45/minuto