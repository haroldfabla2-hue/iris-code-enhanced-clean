# Variables de entorno para IRIS Code
# Configuración para producción en Atlantic.Net

# === CONFIGURACIÓN DE APLICACIÓN ===
APP_NAME=IRIS-Code
VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
IRIS_PORT=8000

# === BASE DE DATOS ===
# Configuración para PostgreSQL en Atlantic.Net
DATABASE_URL=postgresql://iris_code:YOUR_DB_PASSWORD@your-atlantic-host:5432/iris_code_db

# === CACHE Y SESSIONES ===
# Redis para cache y sesiones
REDIS_URL=redis://your-redis-host:6379/1

# === LLM CONFIGURATION ===
# Configuración para MiniMax M2 (gratuito)
LLM_DEFAULT_PROVIDER=minimax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_API_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# === REDIS CONFIGURATION ===
# Si usas Redis gestionado en Atlantic.Net
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=1

# === VECTOR STORE (RAG) ===
# PostgreSQL con pgvector habilitado
VECTOR_DB_ENABLED=true
VECTOR_DIMENSION=384
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === STORAGE CONFIGURATION ===
# Rutas para almacenamiento de archivos
PROJECTS_STORAGE_PATH=/app/projects
TEMPLATES_STORAGE_PATH=/app/templates
LOGS_PATH=/app/logs
UPLOAD_PATH=/app/uploads

# === SECURITY ===
# JWT para autenticación (opcional)
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === EMAIL (Opcional) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password

# === RATE LIMITING ===
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === CORS ===
# Dominios permitidos (actualizar con tu dominio)
ALLOWED_ORIGINS=https://iris.yourdomain.com,https://yourdomain.com

# === WORKERS ===
WORKERS=4
MAX_CONCURRENT_REQUESTS=100