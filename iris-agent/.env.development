# Variables de entorno para el frontend iris-agent
# Conectado al API Gateway unificado

# URL del API Gateway (puerto 8020)
REACT_APP_API_URL=http://localhost:8020
VITE_API_URL=http://localhost:8020

# URLs específicas para diferentes servicios
VITE_FALLBACK_URL=http://localhost:8021
VITE_SILHOUETTE_URL=http://localhost:8022
VITE_ASSETS_URL=http://localhost:8023
VITE_MCP_URL=http://localhost:8027

# Configuración de la aplicación
REACT_APP_APP_NAME="IRIS + Silhouette Unified"
REACT_APP_VERSION=4.0.0
REACT_APP_DESCRIPTION="Plataforma Integrada de Automatización Empresarial"

# Configuración de desarrollo
NODE_ENV=development
REACT_APP_DEBUG=true
REACT_APP_LOG_LEVEL=debug

# Configuración de features
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_OFFLINE_MODE=true
REACT_APP_ENABLE_REAL_TIME=true

# Configuración de UI
REACT_APP_THEME=system
REACT_APP_ANIMATION_DURATION=200
REACT_APP_TOAST_DURATION=5000

# Configuración de API
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_RETRY_ATTEMPTS=3
REACT_APP_CACHE_ENABLED=true
REACT_APP_CACHE_DURATION=300000

# Configuración de WebSocket
REACT_APP_WS_ENABLED=true
REACT_APP_WS_URL=ws://localhost:8020/ws

# URLs de servicios externos (si se necesitan)
REACT_APP_OPENROUTER_URL=https://openrouter.ai/api/v1
REACT_APP_FREEPIK_URL=https://api.freepik.com/v1
REACT_APP_VEO3_URL=https://api.veo3.com/v1

# Configuración de monitoring
REACT_APP_MONITORING_ENABLED=true
REACT_APP_METRICS_INTERVAL=30000
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
FREEPIK_API_KEY=your-freepik-api-key-here
HUGGINGFACE_TOKEN=your-huggingface-token-here
POSTGRES_USER=iris_user
POSTGRES_PASSWORD=IrisSecure2025@Production